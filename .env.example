# ============================================================
# AGENT - Hermes Agent Deployment Template
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# ============================================================

# ── REQUIRED: Primary Groq API Key ──────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL: Extra Groq Keys (auto rotation / load balancing)
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL: Fireworks AI (fallback provider) ───────────────
# Get your key at: https://app.fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxx
# Model to use from Fireworks (fallback model)
# See full list at: https://fireworks.ai/models
FIREWORKS_FALLBACK_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── OPTIONAL: Telegram Bot Token ────────────────────────────
# Required only if using Telegram gateway
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── OPTIONAL: OpenRouter (alternative routing) ──────────────
OPENROUTER_API_KEY=
